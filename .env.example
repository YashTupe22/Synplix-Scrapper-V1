HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=false

# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=https://YOUR_VERCEL_DOMAIN

# For Docker/Render Selenium runtime.
FORCE_HEADLESS=true
CHROME_BIN=/usr/bin/chromium

# Optional: only needed when Flask template frontend should call a separate API origin.
API_BASE_URL=
